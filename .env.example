# ============================================================
# Video Engine — Environment Configuration
# Copy this file to .env and fill in your values
# ============================================================

# --- LLM (Ollama) ---
OLLAMA_URL=http://localhost:11434/api/generate
OLLAMA_MODEL=gemma3:4b

# --- Image Generation (Stable Diffusion — local GPU) ---
SD_MODEL_ID=stabilityai/stable-diffusion-xl-base-1.0
SD_NUM_STEPS=30
SD_GUIDANCE_SCALE=7.5

# --- Audio / TTS (Kokoro) ---
KOKORO_LANG_CODE=a
KOKORO_VOICE=af_heart

# --- Transcription (Whisper) ---
WHISPER_MODEL=medium.en
WHISPER_CACHE_DIR=./whisper_cache

# --- Video Settings ---
VIDEO_FPS=30
VIDEO_BITRATE=20000k
VIDEO_PRESET=slow
FONT_PATH=assets/fonts/Anton-Regular.ttf
FONT_SIZE=60
MAX_LINE_LENGTH=45
MAX_SHORTS_DURATION=60

# --- YouTube Upload ---
YOUTUBE_CLIENT_SECRETS=config/client.json
YOUTUBE_TOKEN_FILE=config/token.json
YOUTUBE_CATEGORY_ID=22
YOUTUBE_PRIVACY_STATUS=private
SKIP_UPLOAD=false

# --- Paths ---
OUTPUT_DIR=output
ASSETS_DIR=assets
BACKGROUND_MUSIC=assets/audio/background_music.wav

# --- Logging ---
LOG_LEVEL=INFO
LOG_FILE=logs/video_engine.log
